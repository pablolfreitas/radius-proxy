import { createClient } from "https://esm.sh/@supabase/supabase-js@2.39.8";

const headers = { "Content-Type": "application/json" };

Deno.serve(async (req) => {
  try {
    if (req.method !== "POST") {
      return new Response("Apenas requisições POST são aceitas.", { status: 405 });
    }

    const update = await req.json();
    
    const supabaseUrl = Deno.env.get("SUPABASE_URL") || "";
    const supabaseServiceRoleKey = Deno.env.get("SUPABASE_SERVICE_ROLE_KEY") || "";
    const telegramToken = Deno.env.get("TELEGRAM_BOT_TOKEN") || "";
    const botPassword = Deno.env.get("BOT_PASSWORD") || ""; 

    if (!telegramToken) {
      console.error("TELEGRAM_BOT_TOKEN não configurado.");
      return new Response("Token do Telegram ausente.", { status: 500 });
    }

    const supabase = createClient(supabaseUrl, supabaseServiceRoleKey);

    const enviarMensagem = async (chatId: number, texto: string, replyMarkup: any = null) => {
      const body: any = {
        chat_id: chatId,
        text: texto,
        parse_mode: "Markdown",
        disable_web_page_preview: true
      };
      if (replyMarkup) body.reply_markup = replyMarkup;

      await fetch(`https://api.telegram.org/bot${telegramToken}/sendMessage`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });
    };

    // MENU PRINCIPAL ATUALIZADO (Com Deletar incluído)
    const menuPrincipalButtons = {
      keyboard: [
        [{ text: "🔎 Buscar" }, { text: "➕ Adicionar" }],
        [{ text: "🗑️ Deletar" }, { text: "🌐 Site" }]
      ],
      resize_keyboard: true,
      one_time_keyboard: false
    };

    // MENU EXIBIDO APENAS DURANTE O FLUXO DE ADIÇÃO OU DELEÇÃO
    const menuCancelarButton = {
      keyboard: [
        [{ text: "❌ Cancelar" }]
      ],
      resize_keyboard: true,
      one_time_keyboard: false
    };

    const botaoInlineSite = {
      inline_keyboard: [
        [{ text: "🖥️ Abrir Portal FortiSearch", url: "https://fortisearch.pages.dev" }]
      ]
    };

    if (update.message && update.message.text) {
      const chatId = update.message.chat.id;
      const telegramId = update.message.from.id;
      const firstName = update.message.from.first_name || "";
      const lastName = update.message.from.last_name || "";
      const nomeCompleto = `${firstName} ${lastName}`.trim() || "Usuário Telegram";
      const text = update.message.text.trim();

      // 1. Verificar autorização
      const { data: usuarioAutorizado, error: authError } = await supabase
        .from("authorized_users")
        .select("telegram_id")
        .eq("telegram_id", telegramId)
        .maybeSingle();

      if (authError) {
        console.error("Erro ao verificar autorização:", authError);
        await enviarMensagem(chatId, "❌ Erro interno ao verificar sua autorização.");
        return new Response("OK", { status: 200 });
      }

      if (!usuarioAutorizado) {
        if (botPassword && text === botPassword) {
          await supabase.from("authorized_users").insert([{ telegram_id: telegramId, username: nomeCompleto }]);
          await enviarMensagem(chatId, `✅ *Acesso Liberado!*\nUse os botões abaixo ou digite \`/comandos\`.`, menuPrincipalButtons);
          return new Response("OK", { status: 200 });
        }
        await enviarMensagem(chatId, `⚠️ *Acesso Restrito!*\n\nPor favor, *envie a senha de liberação* para desbloquear.`);
        return new Response("OK", { status: 200 });
      }

      // LÓGICA DO BOTÃO CANCELAR
      if (text === "❌ Cancelar") {
        await supabase.from("bot_stages").delete().eq("telegram_id", telegramId);
        await enviarMensagem(chatId, "🚫 Operação cancelada. Voltando ao menu principal...", menuPrincipalButtons);
        return new Response("OK", { status: 200 });
      }

      // 2. Verificar se o usuário está em algum fluxo (Adição ou Deleção)
      const { data: userStage } = await supabase
        .from("bot_stages")
        .select("*")
        .eq("telegram_id", telegramId)
        .maybeSingle();

      // --- PROCESSAMENTO DOS FLUXOS ATIVOS ---
      if (userStage) {
        // Fluxo de Deleção
        if (userStage.stage === "aguardando_delete_id") {
          const id = parseInt(text, 10);
          if (isNaN(id)) {
            await enviarMensagem(chatId, "⚠️ Por favor, informe apenas o número do ID para exclusão.", menuCancelarButton);
            return new Response("OK", { status: 200 });
          }

          const { data: itemData } = await supabase.from("fortigates").select("id, nome").eq("id", id).maybeSingle();
          if (!itemData) {
            await enviarMensagem(chatId, `⚠️ Registro com ID *${id}* não foi encontrado. Digite outro ID ou cancele:`, menuCancelarButton);
            return new Response("OK", { status: 200 });
          }

          await supabase.from("fortigates").delete().eq("id", id);
          await supabase.from("bot_stages").delete().eq("telegram_id", telegramId);
          await enviarMensagem(chatId, `🗑️ *Registro ${id} (${itemData.nome}) excluído com sucesso!*`, menuPrincipalButtons);
          return new Response("OK", { status: 200 });
        }

        // Fluxo de Adição: Etapa 1 (Receber o Nome)
        if (userStage.stage === "aguardando_nome") {
          const nomeMaiusculo = text.toUpperCase();
          await supabase.from("bot_stages").update({ stage: "aguardando_ip", temp_nome: nomeMaiusculo }).eq("telegram_id", telegramId);
          await enviarMensagem(chatId, "🔌 *Etapa 2 de 3:*\nDigite apenas o IP.\n\n_Exemplo: 1.1.1.1_", menuCancelarButton);
          return new Response("OK", { status: 200 });
        }

        // Fluxo de Adição: Etapa 2 (Receber o IP)
        if (userStage.stage === "aguardando_ip") {
          const ipLimpo = text.replace(/^https?:\/\//i, "");
          await supabase.from("bot_stages").update({ stage: "aguardando_porta", temp_ip: ipLimpo }).eq("telegram_id", telegramId);
          await enviarMensagem(chatId, "🚪 *Etapa 3 de 3:*\nDigite o número da porta.\n\n_Exemplo: 4443_", menuCancelarButton);
          return new Response("OK", { status: 200 });
        }

        // Fluxo de Adição: Etapa 3 (Receber a Porta e Salvar)
        if (userStage.stage === "aguardando_porta") {
          const portaLimpa = text.replace(":", "");
          const urlFinal = `https://${userStage.temp_ip}:${portaLimpa}`;

          const { data, error } = await supabase.from("fortigates").insert([{ nome: userStage.temp_nome, ip: urlFinal }]).select();
          await supabase.from("bot_stages").delete().eq("telegram_id", telegramId);

          if (error) {
            await enviarMensagem(chatId, "❌ Erro ao salvar no banco de dados.", menuPrincipalButtons);
            return new Response("OK", { status: 200 });
          }

          const novoItem = data[0];
          const sucessoMsg = `✅ *Registro Adicionado com Sucesso!*\n\n🔢 *ID:* ${novoItem.id}\n👤 *Nome:* ${novoItem.nome}\n🔌 *URL:* ${novoItem.ip}`;
          await enviarMensagem(chatId, sucessoMsg, menuPrincipalButtons);

          // Notifica demais usuários
          const { data: users } = await supabase.from("authorized_users").select("telegram_id");
          if (users) {
            const notificacaoMsg = `🔔 *Novo FortiGate Cadastrado!*\n\n👤 *Por:* ${nomeCompleto}\n🔢 *ID:* ${novoItem.id}\n👤 *Nome:* ${novoItem.nome}\n🔌 *URL:* ${novoItem.ip}`;
            for (const u of users) {
              if (u.telegram_id !== telegramId) {
                try { await enviarMensagem(u.telegram_id, notificacaoMsg, botaoInlineSite); } catch { console.error("Erro"); }
              }
            }
          }
          return new Response("OK", { status: 200 });
        }
      }

      // --- INTERAÇÕES DOS BOTÕES DO MENU PRINCIPAL ---

      if (text.startsWith("/start") || text.startsWith("/comandos")) {
        const boasVindas = `👋 Olá! ✨ Seu assistente para encontrar FortiGates está pronto!\n\nSelecione uma opção nos botões abaixo ou digite o texto diretamente para realizar uma busca automática por Nome ou IP.`;
        await enviarMensagem(chatId, boasVindas, menuPrincipalButtons);
        return new Response("OK", { status: 200 });
      }

      if (text === "🔎 Buscar" || text.startsWith("/buscar") || text.startsWith("/ip")) {
        await enviarMensagem(chatId, "🔍 *Busca Automática Ativada!*\n\nNão precisa mais digitar comandos. Apenas digite o texto ou IP que você quer procurar diretamente aqui no chat ou acesse:\n\n *https://fortisearch.pages.dev/*", menuPrincipalButtons);
        return new Response("OK", { status: 200 });
      }

      if (text === "➕ Adicionar" || text.startsWith("/adicionar")) {
        await supabase.from("bot_stages").delete().eq("telegram_id", telegramId);
        await supabase.from("bot_stages").insert([{ telegram_id: telegramId, stage: "aguardando_nome" }]);
        await enviarMensagem(chatId, "📝 *Etapa 1 de 3:*\nDigite o nome do local e não esqueça do circuito, sem aspas.", menuCancelarButton);
        return new Response("OK", { status: 200 });
      }

      if (text === "🗑️ Deletar" || text.startsWith("/delete")) {
        await supabase.from("bot_stages").delete().eq("telegram_id", telegramId);
        await supabase.from("bot_stages").insert([{ telegram_id: telegramId, stage: "aguardando_delete_id" }]);
        await enviarMensagem(chatId, "🗑️ *Exclusão de Registro:*\nDigite o número do ID que deseja excluir:", menuCancelarButton);
        return new Response("OK", { status: 200 });
      }

      if (text === "🌐 Site" || text.startsWith("/site")) {
        await enviarMensagem(chatId, `🌐 *Portal Web FortiSearch:*\n\nAcesse o portal clicando no botão abaixo:`, botaoInlineSite);
        return new Response("OK", { status: 200 });
      }

      // --- BUSCA AUTOMÁTICA INTELIGENTE (TEXTO LIVRE) ---
      // Se não for nenhum comando, o bot decide sozinho se busca por IP ou por Nome
      const ehIP = /^[0-9.]+$/.test(text) || text.includes(".");
      let queryDB = supabase.from("fortigates").select("id, nome, ip").order("nome", { ascending: true });

      if (ehIP) {
        queryDB = queryDB.ilike("ip", `%${text}%`);
      } else {
        queryDB = queryDB.ilike("nome", `%${text}%`);
      }

      const { data: resultados, error: buscaErro } = await queryDB;

      if (buscaErro || !resultados || resultados.length === 0) {
        await enviarMensagem(chatId, `🔍 Nenhuma correspondência encontrada para: *${text}*`, menuPrincipalButtons);
        return new Response("OK", { status: 200 });
      }

      let messageBuffer = `🔍 *Resultados encontrados (${resultados.length}):*\n\n`;
      for (const item of resultados) {
        messageBuffer += `🔢 *ID:* ${item.id}\n👤 *Nome:* ${item.nome}\n🔌 *IP:* ${item.ip}\n\n`;
      }
      await enviarMensagem(chatId, messageBuffer, botaoInlineSite);
      return new Response("OK", { status: 200 });
    }

    return new Response("Ignorado", { status: 200 });
  } catch (err) {
    console.error(err);
    return new Response(JSON.stringify({ error: err.message }), { status: 500, headers });
  }
});
